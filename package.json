{
  "name": "blog",
  "private": true,
  "version": "0.2.2",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "wrangler dev .svelte-kit/cloudflare/_worker.js --port 4173",
    "prepare": "svelte-kit sync && husky",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check . && eslint . --max-warnings=0",
    "lint:fix": "pnpm format && eslint . --fix --max-warnings=0",
    "format": "prettier --write .",
    "test:watch": "vitest",
    "test": "tsx ./scripts/run-tests-with-chromium.ts",
    "test:ui": "vitest --ui",
    "gen:types": "wrangler types",
    "gen:api": "openapi-typescript ./openapi.yml -o ./src/lib/types/schema.d.ts && prettier --write ./src/lib/types/schema.d.ts",
    "deploy:preview": "pnpm build && wrangler versions upload",
    "deploy": "pnpm build && wrangler deploy"
  },
  "dependencies": {
    "@milkdown/core": "^7.19.2",
    "@milkdown/ctx": "^7.19.2",
    "@milkdown/plugin-listener": "^7.19.2",
    "@milkdown/preset-commonmark": "^7.19.2",
    "@milkdown/prose": "^7.19.2",
    "@milkdown/utils": "^7.19.2"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.3",
    "@eslint/js": "^10.0.1",
    "@sveltejs/adapter-cloudflare": "^7.2.8",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/node": "^25",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/ui": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "openapi-typescript": "^7.13.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "svelte": "^5.55.0",
    "svelte-check": "^4.4.5",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "vitest-browser-svelte": "^2.1.0",
    "wrangler": "^4.78.0"
  }
}
