{
  "singleQuote": true,
  "arrowParens": "avoid",
  "importOrder": [
    "^astro(.*)$",
    "^@astrojs(.*)$",
    "^react(.*)$",
    "^vite(.*)$",
    "^eslint(.*)$",
    "^@eslint(.*)$",
    "<THIRD_PARTY_MODULES>",
    "@styles(.*)$",
    "(.css)$",
    "^[./]"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true,
  "importOrderCaseInsensitive": true,
  "plugins": [
    "@trivago/prettier-plugin-sort-imports",
    "prettier-plugin-astro",
    "prettier-plugin-tailwindcss"
  ],
  "overrides": [
    {
      "files": "*.astro",
      "options": {
        "parser": "astro"
      }
    }
  ]
}
